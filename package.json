{
  "name": "carabao",
  "version": "1.0.0",
  "description": "Laravel-like Node.js/Express framework with TypeScript",
  "main": "dist/cjs/carabao/index.js",
  "module": "dist/esm/carabao/index.js",
  "types": "dist/cjs/carabao/index.d.ts",
  "bin": {
    "carabao": "dist/cjs/cli/index.js"
  },
  "scripts": {
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p tsconfig.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "start": "node index.js",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web",
    "framework",
    "express",
    "laravel",
    "typescript"
  ],
  "author": "Mark Wayne Menorca",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "nunjucks": "^3.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/nunjucks": "^3.2.6",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
